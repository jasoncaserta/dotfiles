{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.notify.sh \"Claude\" \"needs attention\" \"$TMUX_PANE\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.notify.sh \"Claude\" \"done!\" \"$TMUX_PANE\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.notify.sh \"Claude\" \"hit an error :(\" \"$TMUX_PANE\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.notify.sh \"Claude\" \"needs attention\" \"$TMUX_PANE\""
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.notify.sh \"Claude\" \"needs attention\" \"$TMUX_PANE\""
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "preferredNotifChannel": "terminal_bell",
  "enabledPlugins": {
    "codex@openai-codex": true
  }
}
