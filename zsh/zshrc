# Ghostty shell integration for shells launched inside tmux or after shell switches.
if [ -n "${GHOSTTY_RESOURCES_DIR:-}" ] && [ -r "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration" ]; then
  builtin source "${GHOSTTY_RESOURCES_DIR}/shell-integration/zsh/ghostty-integration"
fi

# Command-finish alerts for long-running commands.
autoload -Uz add-zsh-hook
typeset -g _terminal_alert_started_at=0
typeset -g _terminal_alert_command=''
typeset -g TERMINAL_ALERT_MIN_SECONDS=${TERMINAL_ALERT_MIN_SECONDS:-3}

_terminal_alert_preexec() {
  _terminal_alert_started_at=$SECONDS
  _terminal_alert_command=$1
}

_terminal_alert_precmd() {
  if (( _terminal_alert_started_at == 0 )); then
    touch "$STARSHIP_CMD_FAST_FILE" 2>/dev/null
    return 0
  fi

  local runtime=$(( SECONDS - _terminal_alert_started_at ))
  local command_text=${_terminal_alert_command%%$'\n'*}
  local notify_message=${command_text[1,60]:-"Command complete"}
  local tmux_window_id=''

  _terminal_alert_started_at=0
  _terminal_alert_command=''

  if (( runtime < 2 )); then
    touch "$STARSHIP_CMD_FAST_FILE" 2>/dev/null
  else
    rm -f "$STARSHIP_CMD_FAST_FILE" 2>/dev/null
  fi

  (( runtime >= TERMINAL_ALERT_MIN_SECONDS )) || return 0

  if [[ -n "${TMUX_PANE:-}" ]] && command -v tmux >/dev/null 2>&1; then
    tmux_window_id=$(tmux display-message -p -t "${TMUX_PANE}" '#{window_id}' 2>/dev/null || printf '')
    notify_message=$(tmux display-message -p -t "${TMUX_PANE}" '#{window_name}' 2>/dev/null || printf '%s' "$notify_message")
  fi

  ("$HOME/.notify.sh" "$notify_message" "done!" "$tmux_window_id") >/dev/null 2>&1 &!
}

_tmux_rename_preexec() {
  if [[ -n "${TMUX_PANE:-}" ]] && command -v tmux >/dev/null 2>&1; then
    local cmd="${1%% *}"
    tmux rename-window -t "${TMUX_PANE}" "${cmd:t}" 2>/dev/null
  fi
}

_tmux_rename_precmd() {
  if [[ -n "${TMUX_PANE:-}" ]] && command -v tmux >/dev/null 2>&1; then
    tmux rename-window -t "${TMUX_PANE}" "zsh" 2>/dev/null
  fi
}

add-zsh-hook preexec _terminal_alert_preexec
add-zsh-hook preexec _tmux_rename_preexec
add-zsh-hook precmd _terminal_alert_precmd
add-zsh-hook precmd _tmux_rename_precmd

claude() {
  local pane="$TMUX_PANE"
  if [[ -n "$pane" ]] && command -v tmux >/dev/null 2>&1; then
    tmux rename-window -t "$pane" "claude" 2>/dev/null
  fi
  command claude "$@"
}

codex() {
  local pane="$TMUX_PANE"
  if [[ -n "$pane" ]] && command -v tmux >/dev/null 2>&1; then
    tmux rename-window -t "$pane" "codex" 2>/dev/null
  fi
  command codex -c features.codex_hooks=true "$@"
}

_prompt_tmux_restore_picker() {
  local resurrect_dir="$HOME/.tmux/resurrect"

  # Bail early if another terminal already started the session
  tmux has-session -t main 2>/dev/null && return 1
  command -v fzf >/dev/null 2>&1 || return 1

  # Source _file_age_str from the shared helpers file
  source "${${(%):-%x}:A:h:h}/scripts/_tmux-save-common.sh"

  local -a entries=()
  local line
  while IFS= read -r line; do
    [[ -n "$line" && -f "$resurrect_dir/$line" ]] && \
      entries+=("auto  $(_file_age_str "$resurrect_dir/$line")"$'\t'"$line")
  done < <(cat "$resurrect_dir/last-auto-list" 2>/dev/null)
  while IFS= read -r line; do
    [[ -n "$line" && -f "$resurrect_dir/$line" ]] && \
      entries+=("manual  $(_file_age_str "$resurrect_dir/$line")"$'\t'"$line")
  done < <(cat "$resurrect_dir/last-manual-list" 2>/dev/null)

  # Fallback to 'last' symlink if no lists
  if (( ${#entries[@]} == 0 )); then
    local resolved
    resolved="$(readlink "$resurrect_dir/last" 2>/dev/null || printf '')"
    [[ -n "$resolved" && -f "$resurrect_dir/$resolved" ]] && \
      entries+=("auto  $(_file_age_str "$resurrect_dir/$resolved")"$'\t'"$resolved")
  fi

  (( ${#entries[@]} == 0 )) && return 1
  entries+=("new session"$'\t')

  local selected
  selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --prompt='Restore tmux? > ' \
    --height=~$(( ${#entries[@]} + 3 )) \
    --layout=reverse \
    --delimiter=$'\t' \
    --with-nth=1 \
    --no-sort \
    --bind 'start:execute-silent(fp=$PPID; (while kill -0 "$fp" 2>/dev/null; do sleep 0.5; tmux has-session -t main 2>/dev/null && kill "$fp" 2>/dev/null && break; done) &)' \
    2>/dev/null) || return 1

  local file
  file=$(printf '%s' "$selected" | cut -d$'\t' -f2)
  [[ -z "$file" ]] && return 1  # "new session" selected

  TMUX_RESTORE_FILE="$resurrect_dir/$file"
  return 0
}

jason() {
  case "${1:-help}" in
    help)
      cat <<'EOF'
Jason terminal help

Ghostty
  Cmd+`            Toggle quick terminal
  Ctrl+Tab         Next tmux tab
  Ctrl+Shift+Tab   Previous tmux tab
  Cmd+T            New tmux tab
  Cmd+W            Close tmux tab
  Cmd+Enter        Toggle fullscreen
  Cmd+Shift+Enter  Zoom current split
  Cmd+D            New split right
  Cmd+Shift+D      New split down
  Cmd+[            Previous split
  Cmd+]            Next split
  Cmd+F            Search scrollback
  Cmd+K            Clear screen

tmux (prefix Ctrl-A)
  prefix |         Split horizontal
  prefix -         Split vertical
  prefix h/j/k/l   Navigate panes
  prefix r         Reload tmux config
  prefix Ctrl-s    Save tmux snapshot
  prefix Ctrl-r    Restore tmux snapshot
  M-Left           Previous tab
  M-Right          Next tab
  Middle-click     Kill clicked tab
EOF
      ;;
    *)
      printf 'Unknown jason command: %s\nRun `jason help`.\n' "$1" >&2
      return 1
      ;;
  esac
}

# zoxide as cd
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh --cmd cd)"

# cd + Tab: show eza --icons entries in fzf (requires: brew install fzf)
if command -v fzf >/dev/null 2>&1 && command -v eza >/dev/null 2>&1; then
  _fzf_eza_cd() {
    local typed="${LBUFFER##* }"
    local base="." query="$typed"
    if [[ "$typed" == */* ]]; then
      base="${typed%/*}"
      query="${typed##*/}"
      [[ -z "$base" ]] && base="/"
    fi
    local selected
    selected=$(eza --icons=always --color=always --only-dirs "$base" 2>/dev/null \
      | fzf --ansi --query="$query" --height=50% --layout=reverse 2>/dev/null)
    [[ -z "$selected" ]] && { zle reset-prompt; return; }
    # Strip ANSI codes then the leading icon + space to get the bare name
    local clean
    clean=$(printf '%s' "$selected" \
      | sed $'s/\033\\[[0-9;]*m//g' \
      | sed 's/^[^ ]* //')
    local cmd="${LBUFFER%% *}"
    [[ "$base" == "." ]] \
      && LBUFFER="$cmd $clean" \
      || LBUFFER="$cmd ${base%/}/$clean"
    zle reset-prompt
  }
  zle -N _fzf_eza_cd

  _tab_or_complete() {
    if [[ -n "$POSTDISPLAY" ]]; then
      zle autosuggest-accept
    elif [[ "$LBUFFER" =~ ^(cd|z)[[:space:]] ]]; then
      _fzf_eza_cd
    else
      zle complete-word
    fi
  }
  zle -N _tab_or_complete
  bindkey '^I' _tab_or_complete
fi

# History
HISTFILE="${HISTFILE:-$HOME/.zsh_history}"
HISTSIZE=${HISTSIZE:-100000}
SAVEHIST=${SAVEHIST:-100000}
setopt HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE SHARE_HISTORY

# fzf key bindings: Ctrl+R (history), Ctrl+T (file search), Alt+C (cd)
[[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && \
  source /opt/homebrew/opt/fzf/shell/key-bindings.zsh

# eza as ls with icons
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons'
fi

# Autosuggestions from history (requires: brew install zsh-autosuggestions)
[[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# Starship prompt — session-scoped flag file avoids cross-session clobber
export STARSHIP_CMD_FAST_FILE="/tmp/.starship_cmd_fast_$$"
_starship_cleanup() { rm -f "$STARSHIP_CMD_FAST_FILE" 2>/dev/null; }
add-zsh-hook zshexit _starship_cleanup
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# Auto-attach Ghostty shells to a persistent tmux session.
if command -v tmux >/dev/null 2>&1; then
  case $- in
    *i*)
      if [ -z "$TMUX" ] && [ "${TERM_PROGRAM:-}" = "ghostty" ] && [ -z "${NO_AUTO_TMUX:-}" ]; then
        if ! tmux list-sessions >/dev/null 2>&1; then
          local TMUX_RESTORE_FILE=''
          local should_restore=0

          if _prompt_tmux_restore_picker; then
            should_restore=1
          fi

          if tmux new-session -d -s main 2>/dev/null; then
            if (( should_restore )) && [ -x "$HOME/Projects/dotfiles/scripts/tmux-restore.sh" ] && [ -n "$TMUX_RESTORE_FILE" ]; then
              tmux attach-session -t main \; run-shell "$HOME/Projects/dotfiles/scripts/tmux-restore.sh '$TMUX_RESTORE_FILE'"
              return
            fi
          else
            local _tmux_wait=0
            while ! tmux has-session -t main 2>/dev/null; do
              (( _tmux_wait++ ))
              if (( _tmux_wait >= 50 )); then
                break
              fi
              sleep 0.1
            done
          fi
        fi
        tmux attach-session -t main 2>/dev/null || tmux attach-session 2>/dev/null
        return
      fi
      ;;
  esac
fi
